      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"179 characters\">Standar SQL: PostgreSQL mematuhi standar SQL yang tepat, sehingga kode yang dijalankan di PostgreSQL dapat dengan mudah dipindahkan ke sistem lain yang mendukung standar tersebut.</span>\"
    </samp>]
