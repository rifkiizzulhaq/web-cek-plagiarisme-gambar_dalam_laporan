    <span class=sf-dump-index>164</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"331 characters\">Docker adalah platform yang memungkinkan pengembang untuk mengotomatisasi penyebaran aplikasi dalam &quot;container&quot;. Container adalah paket perangkat lunak yang berisi semua yang diperlukan untuk menjalankan aplikasi: kode, runtime, pustaka, dan pengaturan sistem. Berikut penjelasan lebih rinci tentang Docker, fungsi, dan manfaatnya:</span>\"
    </samp>]
    <span class=sf-dump-index>165</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"13 characters\">Fungsi docker</span>\"
