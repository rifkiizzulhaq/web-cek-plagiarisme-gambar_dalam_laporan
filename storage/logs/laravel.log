      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"157 characters\">Orchestration: Docker mendukung pengaturan dan pengelolaan banyak container yang berjalan dalam skala besar melalui alat seperti Docker Swarm dan Kubernetes.</span>\"
    </samp>]
