      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"141 characters\">Customizable: VS Code sangat dapat disesuaikan. Anda dapat mengubah tema, key bindings, dan preferensi pengguna sesuai dengan kebutuhan Anda.</span>\"
