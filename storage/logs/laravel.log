      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"125 characters\">Open Source: PostgreSQL adalah perangkat lunak open-source, artinya gratis untuk digunakan dan dapat diubah sesuai kebutuhan.</span>\"
