      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"206 characters\">Efisiensi: Docker containers menggunakan sumber daya sistem dengan lebih efisien dibandingkan dengan virtual machines (VMs), karena container berbagi kernel host dan berjalan sebagai proses yang terisolasi.</span>\"
