      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"147 characters\">Integrasi Git: VS Code memiliki integrasi bawaan dengan Git, memungkinkan pengembang untuk mengelola repositori versi kendali langsung dari editor.</span>\"
