      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"21 characters\">HTML, CSS, Javascript</span>\"
    </samp>]
    <span class=sf-dump-index>89</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"32 characters\">HTML (HyperText Markup Language)</span>\"
    </samp>]
    <span class=sf-dump-index>90</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"339 characters\">HTML adalah bahasa standar yang digunakan untuk membuat dan menyusun halaman web. HTML terdiri dari elemen-elemen yang disebut tags yang digunakan untuk membungkus berbagai bagian konten untuk menampilkannya dengan cara tertentu. Misalnya, &lt;p&gt; digunakan untuk membuat paragraf, &lt;a&gt; untuk membuat tautan, dan &lt;img&gt; untuk menambahkan gambar.</span>\"
    </samp>]
    <span class=sf-dump-index>91</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"28 characters\">CSS (Cascading Style Sheets)</span>\"
    </samp>]
    <span class=sf-dump-index>92</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"313 characters\">CSS digunakan untuk mengontrol tampilan dan tata letak elemen-elemen HTML. Dengan CSS, kita bisa menetapkan gaya seperti warna, font, ukuran, margin, padding, dan tata letak lainnya. CSS dapat diterapkan secara langsung pada elemen HTML (inline), di dalam tag &lt;style&gt; dalam dokumen HTML, atau dalam file terpisah.</span>\"
    </samp>]
    <span class=sf-dump-index>93</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"367 characters\">JavaScript adalah bahasa pemrograman yang digunakan untuk membuat halaman web menjadi interaktif dan dinamis. Dengan JavaScript, kita dapat mengubah konten halaman secara real-time, menangani berbagai peristiwa seperti klik tombol, memvalidasi input form, dan banyak lagi. JavaScript bisa ditulis langsung dalam HTML menggunakan tag &lt;script&gt; atau dalam file terpisah.</span>\"
    </samp>]
    <span class=sf-dump-index>94</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"274 characters\">Bootstrap adalah kerangka kerja (framework) front-end yang populer untuk pengembangan web. Bootstrap menyediakan kumpulan alat dan komponen siap pakai yang memudahkan pengembang dalam membuat situs web yang responsif dan menarik. Berikut beberapa fitur utama dari Bootstrap:</span>\"
    </samp>]
    <span class=sf-dump-index>95</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"21 characters\">Fitur Utama Bootstrap</span>\"
    </samp>]
    <span class=sf-dump-index>96</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"191 characters\">Desain Responsif: Bootstrap menggunakan grid system yang fleksibel sehingga situs web dapat menyesuaikan tampilannya dengan berbagai ukuran layar, mulai dari perangkat seluler hingga desktop.</span>\"
    </samp>]
    <span class=sf-dump-index>97</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"199 characters\">Komponen UI: Bootstrap menyediakan berbagai komponen antarmuka pengguna (UI) seperti tombol, form, tabel, navigasi, modals, carousel, dan banyak lagi, yang dapat langsung digunakan dan dikustomisasi.</span>\"
    </samp>]
    <span class=sf-dump-index>98</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"151 characters\">Utilitas CSS: Bootstrap dilengkapi dengan berbagai utilitas CSS untuk styling elemen-elemen web, seperti pengaturan margin, padding, teks, dan lainnya.</span>\"
    </samp>]
    <span class=sf-dump-index>99</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"169 characters\">JavaScript Plugin: Bootstrap menyediakan plugin JavaScript yang dapat digunakan untuk menambahkan interaktivitas, seperti dropdowns, tooltips, popovers, dan banyak lagi.</span>\"
    </samp>]
    <span class=sf-dump-index>100</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"125 characters\">Customizable: Anda dapat menyesuaikan tampilan dan nuansa Bootstrap dengan mudah menggunakan file konfigurasi LESS atau SASS.</span>\"
