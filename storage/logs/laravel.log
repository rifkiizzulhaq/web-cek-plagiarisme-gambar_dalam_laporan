      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"126 characters\">MinIO dirancang untuk berjalan sebagai container yang ringan dan efisien. Arsitektur MinIO melibatkan beberapa komponen utama:</span>\"
