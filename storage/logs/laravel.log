    <span class=sf-dump-index>199</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"275 characters\">Sebagai landasan utama untuk memastikan keseragaman environment pengembangan di setiap komputer atau laptop, sehingga mengurangi risiko perbedaan konfigurasi sistem yang dapat menyebabkan masalah kompatibilitas pada versi instalasi.Beberapa fitur yang berhasil saya jalankan:</span>\"
    </samp>]
    <span class=sf-dump-index>200</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"19 characters\">Postgresql - Django</span>\"
    </samp>]
    <span class=sf-dump-index>201</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"354 characters\">Saya ditugaskan untuk menggunakan PostgreSQL secara langsung untuk memastikan database berfungsi optimal. Ini dilakukan agar SQL yang digunakan dalam sistem tersebut dapat dieksekusi di berbagai lingkungan yang berbeda, menghindari potensi error, konflik, atau inkonsistensi pada struktur dan data tabel yang mungkin terjadi akibat perbedaan konfigurasi.</span>\"
    </samp>]
    <span class=sf-dump-index>202</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"43 characters\">SLS (Sistem Administrasi Koperasi) - Django</span>\"
    </samp>]
    <span class=sf-dump-index>203</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"428 characters\">Pada hari pertama dan seterusnya, saya ditugaskan untuk menjalankan aplikasi dalam container Docker, memastikan setiap layanan berjalan optimal, serta melakukan pembuatan, pengembangan, dan perbaikan berbagai fitur pada aplikasi. Dalam tugas ini, saya juga bertanggung jawab memastikan kompatibilitas dan performa fitur-fitur tersebut di berbagai environment yang telah ditentukan, termasuk development, staging, dan production.</span>\"
    </samp>]
    <span class=sf-dump-index>204</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"96 characters\">Beberapa fitur yang berhasil saya buat dan pastikan berjalan dengan baik adalah sebagai berikut:</span>\"
    </samp>]
    <span class=sf-dump-index>205</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"549 characters\">Saya memastikan bahwa akun dapat beroperasi dengan lancar saat diakses melalui sistem operasi Linux. Ini mencakup fitur-fitur seperti penyaringan berdasarkan bank, tahun, subledger, dan COA. Selain itu, saya juga memastikan bahwa fungsi-fungsi seperti penambahan data pada akun, pengunggahan dan pengunduhan template jurnal, serta kemampuan untuk melihat, menghapus, memperbarui, dan mencetak berjalan dengan baik. Semua ini saya pastikan berfungsi tanpa hambatan, baik saat dijalankan di sistem operasi Linux maupun saat dideploy ke server. server.</span>\"
    </samp>]
    <span class=sf-dump-index>206</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"561 characters\">Saya memastikan bahwa aplikasi general dapat beroperasi dengan lancar saat diakses melalui sistem operasi Linux. Fitur-fitur seperti filter berdasarkan tahun dan subledger berfungsi dengan baik. Selain itu, saya juga memastikan bahwa fitur-fitur seperti penambahan data pada general, pengunggahan dan pengunduhan template jurnal, serta fungsi untuk melihat, menghapus, memperbarui, mengunduh file, dan mencetak berjalan dengan normal. Semua ini saya pastikan berfungsi tanpa hambatan, baik saat dijalankan di sistem operasi Linux maupun saat dideploy ke server.</span>\"
    </samp>]
    <span class=sf-dump-index>207</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"377 characters\">Saya memastikan bahwa Routes dapat dijalankan tanpa kendala saat diakses melalui sistem operasi Linux. Fitur-fitur seperti penambahan data Routes berfungsi dengan normal, begitu pula dengan proses penugasan (assign) dan penghapusan (deassign) Routes. Semua ini saya pastikan berfungsi tanpa hambatan, baik saat dijalankan di sistem operasi Linux maupun saat dideploy ke server.</span>\"
    </samp>]
    <span class=sf-dump-index>208</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"338 characters\">Saya di tugaskan menggunakan docker untuk mengtasi permasalahan upload file dan download file. Untuk mengatasi upload file dan download file saya menggunakan MiniIO Object Storage dan mengintegrasikan dengan docker agar memudahkan dalam penanganan file banyak sekaligus mengurangi beban pada device dan mempercepat performa pada aplikasi.</span>\"
    </samp>]
    <span class=sf-dump-index>209</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"20 characters\">MinIO Object Storage</span>\"
    </samp>]
    <span class=sf-dump-index>210</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"185 characters\">Saya di tugaskan untuk menggunakan Storage MiniIO untuk mengatasi penampungan file pada aplikasi. Tujuannya untuk meringankan beban kerja pada aplikasi dan tanpa ada penurunan performa.</span>\"
    </samp>]
    <span class=sf-dump-index>211</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"35 characters\">Pembuatan Database pada PostgreeSQL</span>\"
    </samp>]
    <span class=sf-dump-index>212</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"554 characters\">Pada hari pertama dan seterusnya, saya diberikan tugas untuk mengelola sebuah database yang akan menyimpan semua data pada aplikasi. Database pada aplikasi yang ingin di buat, sebelumnya sudah ada database dari pihak PT Cyber Blitz Nusantara tinggal import lalu di terapkan ke aplikasi. Kerena sebelumnya pernah di gunakan dalam aplikasi, karena ada faktor lain yang mengharuskan untuk pindah environment dan teknologi database tersebut di backup lalu mengintegrasikan ke aplikasi baru. Berikut untuk menggunakan database yang sudah ada atau di sediakan.</span>\"
    </samp>]
    <span class=sf-dump-index>213</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
