    <span class=sf-dump-index>105</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"222 characters\">Extensions: Ada ribuan ekstensi yang tersedia di VS Code Marketplace yang memungkinkan pengembang menambahkan berbagai fitur dan fungsionalitas tambahan, seperti dukungan bahasa baru, alat pengujian, tema, dan banyak lagi.</span>\"
    </samp>]
