    <span class=sf-dump-index>107</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"152 characters\">Terminal Terintegrasi: Terminal bawaan memungkinkan Anda menjalankan perintah shell langsung dari VS Code tanpa perlu membuka jendela terminal terpisah.</span>\"
    </samp>]
    <span class=sf-dump-index>108</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"145 characters\">IntelliSense: Fitur ini memberikan saran kode yang cerdas berdasarkan konteks, termasuk pelengkapan otomatis, penjelasan parameter, dan definisi.</span>\"
    </samp>]
    <span class=sf-dump-index>109</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"139 characters\">Emmet: Untuk pengembang web, VS Code mendukung Emmet, yang memungkinkan Anda menulis HTML dan CSS dengan lebih cepat menggunakan singkatan.</span>\"
    </samp>]
    <span class=sf-dump-index>110</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
