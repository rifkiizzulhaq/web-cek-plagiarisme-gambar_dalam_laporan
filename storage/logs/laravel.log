      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"120 characters\">Konsistensi Inline: Semua operasi seperti enkripsi, erasure coding, dan replikasi dilakukan secara inline dan konsisten.</span>\"
