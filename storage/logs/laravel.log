      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"245 characters\">PDM adalah alat manajemen dependensi dan paket untuk proyek Python. Ini mirip dengan pip, poetry, atau conda, tetapi menawarkan fitur tambahan seperti lock file, integrasi dengan PEP 582, dan dukungan untuk menulis konfigurasi dalam format TOML.</span>\"
