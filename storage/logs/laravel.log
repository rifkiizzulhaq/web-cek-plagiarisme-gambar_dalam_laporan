    <span class=sf-dump-index>223</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"83 characters\">Hubungkan Minio Dengan docker dan aplikasi web supaya bisa terhubung secara optimal</span>\"
    </samp>]
    <span class=sf-dump-index>224</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"66 characters\">Gunakan server yang ada di docker untuk mengakses MinIO lalu login</span>\"
    </samp>]
    <span class=sf-dump-index>225</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"48 characters\">Jika berhasil login maka akan tampil seperti ini</span>\"
    </samp>]
    <span class=sf-dump-index>226</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"99 characters\">Pembuatan Aplikasi Website Django - SLS (Sistem Administrasi Koperasi) menggunakan Django Framework</span>\"
    </samp>]
    <span class=sf-dump-index>227</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"640 characters\">Pada hari pertama dan seterusnya, saya diberikan tugas untuk mengembangkan sebuah website Sistem Administrasi Koperasi yang sebelumnya telah dibuat menggunakan framework PHP Yii. Namun, karena sistem tersebut memiliki tingkat kompleksitas yang tinggi, biaya komputasi menjadi sangat mahal dan kurang efisien. Oleh karena itu, saya diarahkan untuk membuat ulang sistem yang sama dengan pendekatan yang lebih optimal menggunakan framework berbeda, yaitu Django. Dengan Django, diharapkan dapat menciptakan solusi yang lebih efisien baik dari segi performa maupun biaya, sambil tetap mempertahankan fungsionalitas utama pada sistem sebelumnya.</span>\"
    </samp>]
    <span class=sf-dump-index>228</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"96 characters\">berikut beberapa fitur yang sudah saya buat dari segi tampilan belakang dan juga logika bisnis :</span>\"
    </samp>]
    <span class=sf-dump-index>229</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"102 characters\">Account: Fitur manajemen akun pengguna yang mencakup pendaftaran, autentikasi, dan pengelolaan profil.</span>\"
    </samp>]
    <span class=sf-dump-index>230</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"13 characters\">Template html</span>\"
    </samp>]
    <span class=sf-dump-index>231</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"15 characters\">Halaman account</span>\"
    </samp>]
    <span class=sf-dump-index>232</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"99 characters\">General: Berbagai pengaturan umum aplikasi untuk memastikan fleksibilitas dan kemudahan penggunaan.</span>\"
    </samp>]
    <span class=sf-dump-index>233</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"15 characters\">Halaman General</span>\"
    </samp>]
    <span class=sf-dump-index>234</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"76 characters\">Routes: Pengelolaan jalur aplikasi, baik untuk API maupun antarmuka pengguna</span>\"
    </samp>]
    <span class=sf-dump-index>235</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"14 characters\">Halaman Routes</span>\"
    </samp>]
    <span class=sf-dump-index>236</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"544 characters\">Kegiatan magang di PT Cybers Blitz Nusantara,bertujuan untuk meningkatkan kompetensi teknis dan pemahaman industri dalam pengembangan perangkat lunak terutama untuk web development,mobile development dan kecerdasan buatan. Melalui pelatihan dan kerjasama untuk memecahkan permasalahan.Kami terlibat dalam berbagai proyek yang mencakup pengembangan aplikasi, pemeliharaan sistem, dan manajemen proyek. Pengalaman ini tidak hanya memperdalam keterampilan teknis tetapi juga memberikan wawasan langsung tentang standar kerja dan etika di industri.</span>\"
    </samp>]
    <span class=sf-dump-index>237</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"351 characters\">Selama magang, Kami menghadapi tantangan dalam penerapan teori yang dipelajari di kelas pada situasi aslinya, seperti pemecahan masalah pada sistem yang kompleks dan adaptasi dengan teknologi baru yang digunakan perusahaan. Hal ini membantu meningkatkan kemampuan analisis, pemecahan masalah, serta kerjasama tim yang sangat dibutuhkan di dunia kerja.</span>\"
    </samp>]
    <span class=sf-dump-index>238</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"20 characters\">Saran untuk Industri</span>\"
    </samp>]
    <span class=sf-dump-index>239</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"182 characters\">Peningkatan Monitoring: Sebaiknya industri mentoring berkelanjutan dalam proses pengembangan aplikasi, sehingga Kami dapat mengatasi Meminimalisir kesalahan dalam tahap pengembangan.</span>\"
    </samp>]
    <span class=sf-dump-index>240</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"25 characters\">Saran untuk Program Studi</span>\"
    </samp>]
    <span class=sf-dump-index>241</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"215 characters\">Peningkatan Proses Pengajaran: Disarankan untuk memasukkan lebih banyak studi kasus dan simulasi proyek nyata dalam proses belajar terutama mata kuliah wajib agar mahasiswa lebih siap ketika memasuki dunia industri.</span>\"
    </samp>]
    <span class=sf-dump-index>242</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"197 characters\">Kesimpulan ini diharapkan dapat menjadi masukan yang membangun bagi semua pihak dalam meningkatkan efektivitas program magang serta memperkuat kompetensi lulusan di bidang Rekayasa Perangkat Lunak.</span>\"
    </samp>]
    <span class=sf-dump-index>243</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"156 characters\">Politeknik Negeri Indramayu. Pedoman Kerja Praktek. Indramayu: Jurusan Teknik Informatika, Program Studi D3 Teknik Informatika, Politeknik Negeri Indramayu.</span>\"
    </samp>]
    <span class=sf-dump-index>244</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"243 characters\">FEBRINA, Anisa; HASRI, Chairumah; SURYANI, Karmila. Pengembangan Standar Pelaksanaan Praktik Kerja Industri (PRAKERIN) Mahasiswa Jurusan Pendidikan Teknik Informatika Dan Komputer. In: Seminar Nasional Informatika (SENATIKA). 2021. p. 342-347.</span>\"
    </samp>]
    <span class=sf-dump-index>245</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"194 characters\">RAHMAWATI, Salma Nur Azizah; SUPRIYANTO, Achmad. Pentingnya Kepemimpinan dan Kerjasama Tim Dalam Implementasi Manajemen Mutu Terpadu. JDMP (Jurnal Dinamika Manajemen Pendidikan), 2020, 5.1: 1-9.</span>\"
    </samp>]
