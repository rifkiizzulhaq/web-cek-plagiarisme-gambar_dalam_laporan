      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"149 characters\">Editor yang Kuat: VS Code menawarkan editor teks yang kuat dengan dukungan syntax highlighting dan auto-completion untuk berbagai bahasa pemrograman.</span>\"
