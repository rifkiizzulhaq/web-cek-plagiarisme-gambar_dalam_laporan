      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"52 characters\">LAMPIRAN 5. CONTOH HALAMAN PENGESAHAN LAPORAN PMI 53</span>\"
    </samp>]
    <span class=sf-dump-index>36</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"18 characters\">Latar Belakang PMI</span>\"
    </samp>]
    <span class=sf-dump-index>37</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"560 characters\">Kami memutuskan untuk melamar posisi magang di PT Cybers Blitz Nusantara karena posisi tersebut sangat sesuai dengan kemampuan kami sebagai fullstack developer. PT Cybers Blitz Nusantara membuka peluang magang dengan menyediakan lima slot untuk posisi full stack developer, yang dirasa sejalan dengan keahlian dan minat kami dalam bidang pengembangan aplikasi berbasis web maupun mobile. Kesempatan ini sangat berharga bagi kami untuk mengembangkan keterampilan teknis, memperluas wawasan,serta berkontribusi pada proyek-proyek yang dikerjakan oleh perusahaan.</span>\"
    </samp>]
    <span class=sf-dump-index>38</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"240 characters\">Kami berharap dapat belajar langsung dari para ahli yang ada di perusahaan, memahami alur kerja tim dalam mengelola proyek-proyek skala besar, serta meningkatkan kemampuan kolaborasi dan komunikasi yang efektif dalam lingkungan kerja nyata.</span>\"
    </samp>]
    <span class=sf-dump-index>39</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"324 characters\">Dengan mengikuti program magang ini, kami juga berharap dapat memberikan kontribusi yang berarti bagi perusahaan melalui keterampilan yang kami miliki, seperti penguasaan teknologi frontend dan backend, pemahaman tentang database, serta kemampuan dalam merancang dan mengembangkan aplikasi yang user-friendly dan fungsional.</span>\"
    </samp>]
    <span class=sf-dump-index>40</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"22 characters\">Tujuan dan Manfaat PMI</span>\"
    </samp>]
    <span class=sf-dump-index>41</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"364 characters\">Tujuan utama kami mengikuti Program Magang Industri adalah untuk mengembangkan kemampuan kami sebagai fullstack developer, baik dari segi teknis maupun non-teknis. Dalam aspek teknis, kami ingin meningkatkan pemahaman dan keahlian kami dalam pengembangan aplikasi, termasuk teknologi frontend dan backend, manajemen database.Dalam proses pembuatan perangkat lunak.</span>\"
    </samp>]
    <span class=sf-dump-index>42</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"335 characters\">Sementara itu, dari sisi non-teknis, kami berharap dapat mengasah keterampilan komunikasi, manajemen waktu, dan kerja sama tim dalam lingkungan perusahaan. Oleh karena itu, kami memutuskan untuk mengisi salah slot magang yang tersedia di PT Cybers Blitz Nusantara, karena posisi tersebut sangat sejalan dengan kompetensi dan minat kami</span>\"
    </samp>]
    <span class=sf-dump-index>43</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"144 characters\">Kami juga percaya bahwa melalui pengalaman ini, kami dapat mempelajari lebih lanjut tentang bagaimana teknologi diterapkan dalam dunia industri.</span>\"
    </samp>]
    <span class=sf-dump-index>44</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"11 characters\">Manfaat PMI</span>\"
    </samp>]
    <span class=sf-dump-index>45</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"96 characters\">Kami juga mendapat beberapa manfaat dari magang PMI di PT Cybers Blitz Nusantara yang meliputi :</span>\"
    </samp>]
    <span class=sf-dump-index>46</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"16 characters\">Manajemen Proyek</span>\"
    </samp>]
    <span class=sf-dump-index>47</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"367 characters\">Selama magang, kami diajarkan pentingnya manajemen proyek, terutama dalam menghadapi proyek berskala industri yang memiliki dinamika dan tantangan yang terus berubah. Kami belajar bagaimana merencanakan, mengatur, dan menyelesaikan tugas sesuai dengan tenggat waktu yang ditetapkan, sekaligus menghadapi kendala-kendala yang muncul di tengah proses pengerjaan proyek.</span>\"
    </samp>]
    <span class=sf-dump-index>48</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"243 characters\">Kemampuan komunikasi menjadi salah satu keterampilan penting yang kami kembangkan selama magang.Kemampuan komunikasi menjadi salah satu keterampilan penting yang kami kembangkan selama magang. Kami belajar cara menyampaikan ide dan berdiskusi.</span>\"
    </samp>]
    <span class=sf-dump-index>49</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"13 characters\">Kerjasama Tim</span>\"
    </samp>]
    <span class=sf-dump-index>50</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"327 characters\">Dalam lingkungan kerja, kami dilatih untuk bekerja sama dengan tim yang terdiri dari berbagai latar belakang dan keahlian. Magang ini memberikan pengalaman langsung tentang bagaimana bekerja dalam tim untuk mencapai tujuan bersama, termasuk pembagian tugas, kolaborasi antar anggota, serta penyelesaian masalah secara kolektif.</span>\"
    </samp>]
    <span class=sf-dump-index>51</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"16 characters\">Kemampuan Teknis</span>\"
    </samp>]
    <span class=sf-dump-index>52</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"209 characters\">Kami memperoleh banyak pengetahuan teknis selama magang, seperti penguasaan teknologi terbaru dalam pengembangan perangkat lunak, pemrograman backend dan frontend, manajemen database dalam pengembangan sistem.</span>\"
    </samp>]
    <span class=sf-dump-index>53</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"20 characters\">Kemampuan Non Teknis</span>\"
    </samp>]
    <span class=sf-dump-index>54</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"253 characters\">Selain keterampilan teknis, kami juga meningkatkan kemampuan non-teknis seperti pengelolaan waktu, pemecahan masalah, adaptasi terhadap lingkungan kerja yang terus berubah. Hal ini membantu kami menjadi tangguh dalam menghadapi tantangan di dunia kerja.</span>\"
    </samp>]
    <span class=sf-dump-index>55</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"477 characters\">Dalam ruang lingkup pelaksanaan Program Magang Industri (PMI), kami fokus pada menjalin komunikasi dan kerja sama tim yang berkaitan dengan bidang pembuatan website baik frontend maupun backend. Beberapa kegiatan utama mencakup pengembangan aplikasi berbasis web menggunakan framework seperti Django, Laravel, dan Yii. Selain itu, kami juga magang juga didorong untuk memahami proses perancangan, implementasi, dan pemeliharaan aplikasi, serta meningkatkan keterampilan teknis.</span>\"
    </samp>]
    <span class=sf-dump-index>56</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"85 characters\">Beberapa Ruang Lingkup Program Magang Industri di PT Cybers Blitz Nusantara meliputi:</span>\"
    </samp>]
    <span class=sf-dump-index>57</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"26 characters\">Pembuatan Aplikasi Website</span>\"
    </samp>]
    <span class=sf-dump-index>58</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"105 characters\">Membuat aplikasi yang mengutamakan kenyamanan pengguna dan struktur logika bisnis yang jelas dan efisien.</span>\"
    </samp>]
    <span class=sf-dump-index>59</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"93 characters\">Mengimplementasikan desain yang responsif serta fitur-fitur yang memenuhi kebutuhan pengguna.</span>\"
    </samp>]
    <span class=sf-dump-index>60</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"29 characters\">Pemeliharaan Aplikasi Website</span>\"
    </samp>]
    <span class=sf-dump-index>61</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"81 characters\">Menyelesaikan masalah bug, memperbarui fitur, dan meningkatkan performa aplikasi.</span>\"
    </samp>]
    <span class=sf-dump-index>62</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"88 characters\">Melakukan pengawasan sistem secara rutin untuk menjaga keamanan dan stabilitas aplikasi.</span>\"
    </samp>]
    <span class=sf-dump-index>63</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"104 characters\">Berkolaborasi dalam tim untuk mengintegrasikan proses pengembangan dan operasional secara terus menerus.</span>\"
    </samp>]
    <span class=sf-dump-index>64</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"19 characters\">2.1.Lokasi Industri</span>\"
    </samp>]
    <span class=sf-dump-index>65</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"83 characters\">Jl. Sukanagara No.31, Antapani Kidul, Kec. Antapani, Kota Bandung, Jawa Barat 40291</span>\"
    </samp>]
    <span class=sf-dump-index>66</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"16 characters\">Sejarah Industri</span>\"
    </samp>]
    <span class=sf-dump-index>67</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"381 characters\">PT. CYBERS BLITZ NUSANTARA adalah perusahaan yang berdiri pada tahun 2015, dan bergerak di bidang perdagangan umum dan jasa. Pada awal pendiriannya, PT. CYBERS BLITZ NUSANTARA lebih memfokuskan pada pekerjaan terkait sistem informasi berbasis Web Base pada perusahaan BUMN. Sejalan dengan perkembangan perusahaan PT. CYBERS BLITZ NUSANTARA mulai mengembangan kebutuhan penggunanya.</span>\"
    </samp>]
    <span class=sf-dump-index>68</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"17 characters\">Struktur Industri</span>\"
    </samp>]
    <span class=sf-dump-index>69</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"499 characters\">Dalam hal ini, saya bergabung dalam struktur organisasi selama masa magang sebagai software engineer, di mana saya mendapatkan kesempatan berharga untuk belajar, mengembangkan keterampilan, dan berkontribusi secara langsung dalam berbagai proyek dengan bidang pengembangan perangkat lunak berbasis website. Selama masa magang, saya menerima bimbingan dari Bapak Nur Ichsan, selaku Direktur Cyber Blitz Nusantara, yang memberikan arahan sesuai dengan kebutuhan industri baik teknis maupun non teknis.</span>\"
    </samp>]
    <span class=sf-dump-index>70</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"15 characters\">Visi Perusahaan</span>\"
    </samp>]
    <span class=sf-dump-index>71</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>matches</span>\" => <span class=sf-dump-note>array:1</span> [ &#8230;1]
      \"<span class=sf-dump-key>text</span>\" => \"<span class=sf-dump-str title=\"95 characters\">Menjadi perusahaan Jasa Konsultansi yang Produktif dan Inovatif dalam memberikan solusi terbaik</span>\"
    </samp>]
    <span class=sf-dump-index>72</span> => <span class=sf-dump-note>array:2</span> [<samp data-depth=3 class=sf-dump-compact>
